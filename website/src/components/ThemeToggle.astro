---

<div class="theme-switcher">
  <button class="theme-random-btn" id="theme-random" type="button" aria-label="Random theme" title="Random theme">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="2" width="20" height="20" rx="3"/>
      <circle cx="8" cy="8" r="1.5" fill="currentColor"/>
      <circle cx="16" cy="8" r="1.5" fill="currentColor"/>
      <circle cx="8" cy="16" r="1.5" fill="currentColor"/>
      <circle cx="16" cy="16" r="1.5" fill="currentColor"/>
      <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
    </svg>
  </button>
  <button class="theme-btn" id="theme-toggle" type="button" aria-label="Switch theme" aria-haspopup="true" aria-expanded="false" aria-controls="theme-dropdown">
    <span class="theme-icon" id="theme-current-icon" set:html={themes[0].icon}></span>
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
  </button>
  <div class="theme-dropdown" id="theme-dropdown" role="menu">
    {themes.map((t) => (
      <button class="theme-option" data-theme-id={t.id} data-theme-icon={t.icon} data-theme-color={t.color} role="menuitem" type="button">
        <span class="theme-option-icon" set:html={t.icon}></span>
        {t.label}
      </button>
    ))}
  </div>
</div>

<style>
  .theme-switcher {
    position: relative;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .theme-random-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, transform 0.3s;
  }

  .theme-random-btn:hover {
    color: var(--text);
    border-color: var(--text-muted);
  }

  .theme-random-btn:active {
    transform: rotate(180deg);
  }

  .theme-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.8rem;
    font-family: var(--font-sans);
    transition: color 0.2s, border-color 0.2s;
    min-height: 36px;
  }

  .theme-btn:hover {
    color: var(--text);
    border-color: var(--text-muted);
  }

  .theme-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .theme-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 6px;
    min-width: 150px;
    z-index: 200;
    box-shadow: 0 8px 30px var(--card-shadow);
  }

  .theme-dropdown.open {
    display: flex;
    flex-direction: column;
  }

  .theme-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    font-size: 0.85rem;
    color: var(--text-muted);
    border-radius: 6px;
    border: none;
    background: transparent;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: background 0.15s, color 0.15s;
    min-height: 36px;
    width: 100%;
    text-align: left;
  }

  .theme-option:hover {
    background: var(--icon-bg);
    color: var(--text);
  }

  .theme-option.active {
    color: var(--red);
    font-weight: 600;
  }

  .theme-option-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
</style>

<script>
  const themeToggle = document.getElementById('theme-toggle');
  const themeDropdown = document.getElementById('theme-dropdown');
  const currentIcon = document.getElementById('theme-current-icon');
  const themeRandomBtn = document.getElementById('theme-random');
  const themeOptions = Array.from(themeDropdown?.querySelectorAll<HTMLElement>('[role="menuitem"]') || []);

  const allThemeIds = themeOptions.map(opt => opt.getAttribute('data-theme-id')!);
  const themeColors: Record<string, string> = {};
  for (const opt of themeOptions) {
    themeColors[opt.getAttribute('data-theme-id')!] = opt.getAttribute('data-theme-color')!;
  }

  function getCurrentTheme(): string {
    const attr = document.documentElement.getAttribute('data-theme');
    return attr || 'dark';
  }

  function updateActiveState() {
    const current = getCurrentTheme();
    for (const opt of themeOptions) {
      const isActive = opt.getAttribute('data-theme-id') === current;
      opt.classList.toggle('active', isActive);
      if (isActive && currentIcon) {
        const iconHtml = opt.getAttribute('data-theme-icon');
        if (iconHtml) currentIcon.innerHTML = iconHtml;
      }
    }
  }

  function applyTheme(name: string) {
    const transitionName = name;

    const apply = () => {
      if (name === 'dark') {
        document.documentElement.removeAttribute('data-theme');
      } else {
        document.documentElement.setAttribute('data-theme', name);
      }
      localStorage.setItem('theme', name);
      updateActiveState();
      document.documentElement.removeAttribute('data-theme-transition');
      window.dispatchEvent(new CustomEvent('themechange', { detail: { theme: name } }));
    };

    if (document.startViewTransition) {
      document.documentElement.setAttribute('data-theme-transition', transitionName);
      document.startViewTransition(apply);
    } else {
      apply();
    }
  }

  function openDropdown() {
    themeDropdown?.classList.add('open');
    themeToggle?.setAttribute('aria-expanded', 'true');
  }

  function closeDropdown(refocus = false) {
    themeDropdown?.classList.remove('open');
    themeToggle?.setAttribute('aria-expanded', 'false');
    if (refocus) themeToggle?.focus();
  }

  themeToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = themeDropdown?.classList.contains('open');
    if (isOpen) {
      closeDropdown();
    } else {
      openDropdown();
      themeOptions[0]?.focus();
    }
  });

  themeToggle?.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      openDropdown();
      themeOptions[0]?.focus();
    }
  });

  for (const opt of themeOptions) {
    opt.addEventListener('click', (e) => {
      e.stopPropagation();
      const id = opt.getAttribute('data-theme-id');
      if (id) applyTheme(id);
      closeDropdown(true);
    });
  }

  themeDropdown?.addEventListener('keydown', (e) => {
    const idx = themeOptions.indexOf(document.activeElement as HTMLElement);
    if (e.key === 'Escape') {
      e.preventDefault();
      closeDropdown(true);
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      themeOptions[(idx + 1) % themeOptions.length]?.focus();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      themeOptions[(idx - 1 + themeOptions.length) % themeOptions.length]?.focus();
    } else if (e.key === 'Tab') {
      closeDropdown();
    }
  });

  document.addEventListener('click', () => {
    closeDropdown();
  });

  // Random theme button
  themeRandomBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    closeDropdown();
    const current = getCurrentTheme();
    const choices = allThemeIds.filter((t) => t !== current);
    const randomTheme = choices[Math.floor(Math.random() * choices.length)];
    applyTheme(randomTheme);
  });

  // Initialize active state
  updateActiveState();
</script>
