---
import { getTranslation } from '../i18n/index';
import Terminal from './Terminal.astro';

interface Props {
  locale?: string;
}

const { locale = 'en' } = Astro.props;
const t = getTranslation(locale);
---

<section class="section comparison" id="comparison">
  <div class="container">
    <h2 class="section-title reveal">
      {t('comparison.heading')} <span class="gradient-text">{t('comparison.heading.accent')}</span>
    </h2>
    <p class="section-subtitle reveal">{t('comparison.subtitle')}</p>
    <div class="comparison-grid">
      <div class="comparison-side comparison-old reveal">
        <h3 class="comparison-label comparison-label--old">{t('comparison.old')}</h3>
        <Terminal title="bash">
          <div class="terminal-line">
            <span class="terminal-prompt">$ </span><span class="terminal-command"
              >lsof -iTCP:3000 -sTCP:LISTEN</span
            >
          </div>
          <div class="terminal-line">
            <span class="terminal-output">node 12847 user 23u IPv4 TCP *:3000</span>
          </div>
          <div class="terminal-line">
            <span class="terminal-prompt">$ </span><span class="terminal-command">kill -9 12847</span>
          </div>
          <div class="terminal-line">
            <span class="terminal-prompt">$ </span><span class="terminal-command"
              >lsof -iTCP:3000 -sTCP:LISTEN</span
            >
          </div>
          <div class="terminal-line">
            <span class="terminal-error"># still alive... try again?</span>
          </div>
          <div class="terminal-line">
            <span class="terminal-prompt">$ </span><span class="terminal-command">kill -SIGKILL 12847</span>
          </div>
        </Terminal>
      </div>
      <div class="comparison-side comparison-new reveal" style="--delay: 0.15s">
        <h3 class="comparison-label comparison-label--new">{t('comparison.new')}</h3>
        <Terminal title="slay">
          <div class="terminal-line">
            <span class="terminal-prompt">$ </span><span class="terminal-command">slay 3000</span>
          </div>
          <div class="terminal-line">
            <span class="terminal-output">3000 &gt; </span><span class="terminal-warning">node</span><span
              class="terminal-output"
            >
              PID 12847 (Dev Server)</span
            >
          </div>
          <div class="terminal-line">
            <span class="terminal-success">killed PID 12847 on port 3000 [SIGKILL]</span>
          </div>
          <div class="terminal-line">&nbsp;</div>
          <div class="terminal-line">
            <span class="terminal-success">Done in 0.2s</span>
          </div>
          <div class="terminal-line">&nbsp;</div>
        </Terminal>
      </div>
    </div>
  </div>
</section>

<style>
  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: start;
  }

  .comparison-label {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 12px;
    padding: 6px 14px;
    border-radius: 20px;
    display: inline-block;
  }

  .comparison-label--old {
    color: var(--text-muted);
    background: var(--icon-bg);
  }

  .comparison-label--new {
    color: var(--green);
    background: rgba(81, 207, 102, 0.1);
  }

  .comparison-old :global(.terminal) {
    opacity: 0.7;
  }

  .comparison-new :global(.terminal) {
    border-color: var(--green);
    box-shadow: 0 0 30px rgba(81, 207, 102, 0.08);
  }

  @media (max-width: 768px) {
    .comparison-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
